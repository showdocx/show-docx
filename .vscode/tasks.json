{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ShowDocx: Build",
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "ShowDocx: Watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Watching extension",
          "endsPattern": "Watching extension"
        }
      }
    }
  ]
}
