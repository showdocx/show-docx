{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run ShowDocx Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/test/workspace"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "ShowDocx: Watch"
    }
  ]
}
